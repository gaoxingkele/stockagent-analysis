{
  "project_name": "stockagent-analysis",
  "market": "CN-A",
  "default_decision_labels": [
    "buy",
    "hold",
    "sell"
  ],
  "debate_rounds": 2,
  "decision_threshold_buy": 70,
  "decision_threshold_sell": 50,
  "multi_model_weight_mode": true,
  "data_backend": {
    "mode": "combined",
    "default_sources": [
      "tushare",
      "akshare"
    ],
    "fallback_order": [
      "tushare",
      "akshare"
    ]
  },
  "llm": {
    "enabled": true,
    "default_provider": "grok",
    "multi_eval_providers": [
      "grok"
    ],
    "multi_model_weight_providers": [
      "grok",
      "gemini"
    ],
    "default_providers": [
      "grok",
      "qwen",
      "deepseek"
    ],
    "candidate_providers": [
      "gemini",
      "kimi",
      "minmax",
      "doubao",
      "glm"
    ],
    "supported_providers": [
      "kimi",
      "grok",
      "gemini",
      "deepseek",
      "glm",
      "perplexity",
      "minmax",
      "chatgpt",
      "openai",
      "claude",
      "doubao",
      "qwen"
    ],
    "temperature": 0.3,
    "max_tokens": 600,
    "request_timeout_sec": 45,
    "provider_timeout_sec": 600,
    "agent_call_timeout_sec": 120,
    "max_agent_concurrency": 6,
    "multi_turn_default": true
  },
  "output_dir": "output/runs",
  "score_fusion": {
    "local_weight": 0.6,
    "llm_weight": 0.4
  },
  "breakout_detection": {
    "version": "v2",
    "comment": "v1=旧版(仅形态检测), v2=新版(含突破确认+量能验证)",
    "confirm_bars": 2,
    "volume_ratio_threshold": 1.3,
    "retest_tolerance_pct": 1.0
  }
}