    "multi_model_weight_providers": [
      "kimi",
      "grok",
      "gemini"
    ],
    "default_providers": [
      "deepseek",
      "grok",
      "glm"
    ],
    "candidate_providers": [
      "kimi",
      "gemini",
      "doubao",
      "minmax"
    ],
    "supported_providers": [
      "kimi",
      "grok",
      "gemini",
      "deepseek",
      "glm",
      "perplexity",
      "minmax",
      "chatgpt",
      "openai",
