# ===== StockAgent Web 配置示例 =====
# 复制为 .env 后填入实际值

# === 应用 ===
APP_NAME="StockAgent"
APP_ENV=development           # development / production
DEBUG=true
SECRET_KEY=change-this-to-random-string-at-least-32-chars
BASE_URL=http://localhost:8000   # 公网部署时改为 ngrok 域名

# === 服务器 ===
HOST=0.0.0.0
PORT=8000

# === 数据库 ===
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === 管理员 ===
ADMIN_PHONE=18606099618

# === 积分配置 ===
POINTS_REGISTER_BONUS=100
POINTS_INVITE_NEW_USER=50       # 通过邀请码注册的新人额外得
POINTS_INVITE_REFERRER=100      # 介绍人奖励
POINTS_ANALYZE_FULL_COST=20         # LLM 全量评分(首次)
POINTS_ANALYZE_FULL_CACHE_HIT=10    # LLM 全量当日命中缓存
POINTS_ANALYZE_QUANT_COST=1         # 量化评分(已有 LLM 历史时默认走此)
QUANT_CACHE_SAME_DAY=true           # 同日同股 quant 复用结果(仍扣 1 积分)

# === 验证码 ===
SMS_PROVIDER=mock                # mock / aliyun / twilio
SMS_TEST_CODE=8888               # mock 模式: admin 万能码
SMS_CODE_TTL_SECONDS=300         # 5 分钟
SMS_RATE_LIMIT_PER_DAY=5         # 同手机号每日发送上限

# === Tushare (复用现有 .env) ===
TUSHARE_TOKEN=

# === LLM Providers (复用现有 .env) ===
KIMI_API_KEY=
GROK_API_KEY=
DOUBAO_API_KEY=
DEEPSEEK_API_KEY=

# === JWT ===
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === 健康检查定时 ===
HEALTHCHECK_CRON_ENABLED=true
HEALTHCHECK_CRON_HOURS="9-16"    # 北京时间 9:00-16:00 每小时
HEALTHCHECK_TZ=Asia/Shanghai

# === 订阅自动跟踪 (P10) ===
SUBSCRIPTION_CRON_ENABLED=true
SUBSCRIPTION_CRON_TIME="16:30"   # 每个交易日 16:30 自动跑订阅 quant
SUBSCRIPTION_DEFAULT_THRESHOLD=5 # 默认 score 变化 ≥5 触发推送

# === 推送渠道 (P11) ===
FEISHU_WEBHOOK_DEFAULT=          # 用户可在 /me/notify-channels 单独配置
DINGTALK_WEBHOOK_DEFAULT=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# === 日志 ===
LOG_LEVEL=INFO                   # DEBUG / INFO / WARNING / ERROR
LOG_DIR=./logs
LOG_MAX_BYTES=52428800           # 50MB
LOG_BACKUP_COUNT=7

# === 国际化 ===
DEFAULT_LANGUAGE=zh-CN
SUPPORTED_LANGUAGES=zh-CN,en-US,zh-TW

# === 限流 ===
REGISTER_RATE_LIMIT_PER_IP_DAY=5
ANALYZE_QUEUE_PER_USER=1         # 单用户同时最多 1 只在跑
